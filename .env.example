# ============================================================
# AI Meeting Copilot — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=copilot_user
POSTGRES_PASSWORD=copilot_password
POSTGRES_DB=ai_copilot_db
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Backend ───────────────────────────────────────────────────
BACKEND_PORT=3000
